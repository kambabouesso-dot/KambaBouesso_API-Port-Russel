NODE_ENV=development
APP_NAME=mon_application
PORT=8000
API_URL=http://localhost:8000
URL_MONGO=mongodb+srv://<user>:<password>@<cluster>/<db>?appName=<app>
JWT_SECRET=replace-with-a-strong-secret-at-least-24-chars
JWT_EXPIRES_IN=2h
JWT_AUDIENCE=api-port-russel-client
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MS=600000
